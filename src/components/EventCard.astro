---
import clsx from "clsx";
import AgendaSpeaker from "./AgendaSpeaker.astro";
import AgendaSpeakerList from "./AgendaSpeakerList.astro";

type Speaker = {
  name: string;
  url: string;
  description: string;
  imageUrl: string;
};

type Props = {
  name: string;
  language: string;
  length: string;
  room: string;
  multiple: boolean;
  speaker: Speaker | Speaker[];
};

const { name, language, speaker, length, multiple, room } = Astro.props;
---

<li
  class={clsx("flex flex-col md:flex-row gap-6 overflow-hidden w-full", {
    "splide__slide md:m-6 mx-2 md:max-w-[90%] relative": multiple,
    "px-2 md:px-0": !multiple,
  })}
>
  <div
    class={clsx("rounded-3xl flex flex-col w-full bg-[#232323]", {
      "md:bg-[#2E2E2E]": multiple,
    })}
  >
    <div class="p-6 h-full">
      <div class="flex justify-start pb-6">
        <span
          class="block bg-slate-300 text-black px-3 py-2 rounded-3xl text-sm"
        >
          {length}
        </span>

        <span
          class="block bg-slate-300 text-black px-3 py-2 mx-2 rounded-3xl text-sm"
        >
          {language}
        </span>
        <span
          class="block border-slate-300 border text-white px-3 py-2 mx-2 rounded-3xl text-sm ml-auto"
        >
          {room}
        </span>
      </div>
      <h2 class="text-2xl md:text-4xl font-black">{name}</h2>
      <!-- If !speaker -->
      {!speaker && <hr class="h-px my-8 border-dashed" />}
    </div>
    <!--If speaker -->
    {
      speaker && (
        <div class="w-full bg-[#323232] rounded-b-3xl p-6 justify-self-end pane-parent">
          {Array.isArray(speaker) ? (
            <div class="flex flex-col flex-grow items-stretch min-w-md w-full sm:flex-row sm:overflow-hidden">
              {speaker.map((_speaker, index) => (
                <div
                  class={clsx(
                    "duration-700 ease-in-out h-20 flex-grow overflow-hidden pane relative transition-all",
                    {
                      active: index === 0,
                    },
                  )}
                >
                  <AgendaSpeakerList
                    { ..._speaker}
                  ></AgendaSpeaker>
                </div>
              ))}
            </div>
          ) : (
            <AgendaSpeaker {...speaker} />
          )}
        </div>
      )
    }
  </div>
</li>

<style lang="scss" is:global>
  .pane {

    &:not(.active) {
      cursor: pointer;
    }

    .content {
      display: none;

      @media (max-width: 640px) {
        display: block;
      }
    }



    &.active {

      flex-grow: 10;
      max-width: 100%;

      div:first-child>a:first-child {
        pointer-events: none;
      }
  
      .content {
        display: flex;
      }
    }

  }
</style>
