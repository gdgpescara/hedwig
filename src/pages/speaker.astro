---
import { changeLanguage, t } from "i18next";
import SpeakersComponent from "../components/SpeakersComponent.astro";
import { speakersData } from "../data/speakers-data";
import Layout from "../layouts/Layout.astro";

changeLanguage("en");

const speakers = Object.keys(speakersData);
